{
  "name": "backforge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @backforge/api --filter @backforge/mcp dev",
    "dev:api": "pnpm --filter @backforge/api dev",
    "dev:mcp": "pnpm --filter @backforge/mcp dev",
    "dev:web": "pnpm --filter @backforge/web dev",
    "mcp": "pnpm --silent --filter @backforge/mcp exec tsx src/index.ts",
    "db:generate": "pnpm --filter @backforge/api db:generate",
    "db:migrate": "pnpm --filter @backforge/api db:migrate",
    "db:studio": "pnpm --filter @backforge/api db:studio",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^20.17.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
